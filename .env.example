# ============================================================
# Mimir — environment variables
# Copy this to `.env` and fill in. Never commit `.env`.
# In Vercel: add these in Project Settings → Environment Variables.
# ============================================================

# Required ----------------------------------------------------

# Your Anthropic API key (https://console.anthropic.com)
NUXT_ANTHROPIC_API_KEY=sk-ant-...

# Password gate (any string — only you should know it)
NUXT_APP_PASSWORD=change-me-to-something-real

# Optional (recommended) --------------------------------------

# ElevenLabs API key (https://elevenlabs.io)
# Free tier: 10k chars/month. Mimir falls back to browser TTS if missing.
NUXT_ELEVENLABS_API_KEY=

# ElevenLabs voice ID. Default is "Brian" (calm, considered).
# Browse voices at https://elevenlabs.io/app/voice-library
# Defaults to nPczCjzI2devNBz1zQrb if unset.
NUXT_ELEVENLABS_VOICE_ID=nPczCjzI2devNBz1zQrb

# Lead generation pipeline
# -------------------------------------------------------------
# Apify is REQUIRED — there's no free fallback for Google Maps scraping.
# Hunter + MillionVerifier are OPTIONAL — Mimir falls back to website-scrape
# + MX-check (free) when these aren't set. Quality drops ~20% in cheap mode.

# REQUIRED — Apify token (https://apify.com → Settings → Integrations → Personal API tokens)
# Cost: ~$0.05 per 15-lead search. Free tier covers a few searches.
NUXT_APIFY_API_TOKEN=apify_api_uRScJstY5MlKa6NQNs2hR3PLEAUH3S1Uyzxg

# OPTIONAL — Apify actor slugs for multi-source + enrichment
# Each one falls back to a sensible default if unset. Override only if the
# default actor moves or you find a better one.
NUXT_APIFY_YELP_ACTOR=compass~yelp-scraper
NUXT_APIFY_BBB_ACTOR=epctex~bbb-search-scraper
NUXT_APIFY_LINKEDIN_ACTOR=apimaestro~linkedin-company-employees
NUXT_APIFY_INDEED_ACTOR=misceres~indeed-scraper

# OPTIONAL — Hunter.io API key (https://hunter.io → API)
# $49/mo Starter for 500 searches. Skip to use free website scraping.
NUXT_HUNTER_API_KEY=2316002106950f4b57b2fd93ab1368238d1d1e2c

# OPTIONAL — MillionVerifier API key (https://app.millionverifier.com → API)
# ~$0.005/check. Skip to use free MX-record check.
NUXT_MILLIONVERIFIER_API_KEY=bXsBMiNUVq0iYiXks0hkRjhAn

# Live agency data integrations (stubbed in v1, wire when ready)
# -------------------------------------------------------------

# HubSpot Private App access token
NUXT_HUBSPOT_API_KEY=

# Cal.com webhook secret — set in Cal.com Settings → Developer → Webhooks
NUXT_CAL_WEBHOOK_SECRET=

# Documenso (self-hosted) — proposal e-sign
# Base URL of your Documenso instance + a Personal API token (User → API Tokens)
NUXT_DOCUMENSO_API_URL=
NUXT_DOCUMENSO_API_KEY=
NUXT_DOCUMENSO_WEBHOOK_SECRET=
# Per-tier template IDs (create three templates in Documenso UI, paste their IDs)
NUXT_DOCUMENSO_TEMPLATE_STARTER=
NUXT_DOCUMENSO_TEMPLATE_GROWTH=
NUXT_DOCUMENSO_TEMPLATE_AUTHORITY=

# Stripe — billing
# Get the secret key (sk_live_... or sk_test_...) from Stripe dashboard → Developers → API keys
NUXT_STRIPE_SECRET_KEY=
NUXT_STRIPE_WEBHOOK_SECRET=
# Per-tier price IDs (create three products + prices in Stripe, paste price_ID)
NUXT_STRIPE_PRICE_STARTER=
NUXT_STRIPE_PRICE_GROWTH=
NUXT_STRIPE_PRICE_AUTHORITY=

# Money pipeline tuning — what MRR equals "W2 replaced"; monthly burn for runway calcs
NUXT_TARGET_MRR=15000
NUXT_MONTHLY_BURN=220

# Smartlead / Instantly API key
NUXT_SMARTLEAD_API_KEY=
NUXT_INSTANTLY_API_KEY=

# Local sequence sender — Gmail SMTP via App Passwords
# https://myaccount.google.com/apppasswords (2FA must be enabled)
# Numbered inboxes (1, 2, 3...) for rotation. Daily cap = 30/inbox.
NUXT_GMAIL_INBOX_1_EMAIL=adam@nordicnerdhq.com
NUXT_GMAIL_INBOX_1_PASSWORD=fqql iigr wckb sbkv
NUXT_GMAIL_INBOX_2_EMAIL=adam@getnordicnerd.com
NUXT_GMAIL_INBOX_2_PASSWORD=qype jgkj vtiw pplo


# CAN-SPAM required postal address
NUXT_PHYSICAL_ADDRESS=1419 avenue d ne, winter haven, fl 33880

# Optional — secret for the daily-send cron endpoint (lets Cowork scheduled task auth without cookie)
NUXT_CRON_SECRET=May-Odin-slay-those-giants!

# Persistent state — Vercel KV (Upstash) for sequence queue, briefings, conversation memory
# -------------------------------------------------------------
# In Vercel: Storage → Create → KV. Copy KV_REST_API_URL + KV_REST_API_TOKEN.
# (Or any Upstash Redis — same env vars work under the UPSTASH_REDIS_REST_* names.)
# Without these, Mimir falls back to a local JSON file (dev only — DO NOT use in prod).
KV_REST_API_URL=
KV_REST_API_TOKEN=

# GitHub — lets Mimir open PRs against managed repos
# -------------------------------------------------------------
# Create a fine-grained PAT at https://github.com/settings/tokens?type=beta
# Repository access: select "Only select repositories" → AdamDeLeon530/mimir AND AdamDeLeon530/NordicNerd
# Permissions: Contents (Read & Write), Pull requests (Read & Write), Metadata (Read)
NUXT_GITHUB_TOKEN=
NUXT_GITHUB_OWNER=AdamDeLeon530
