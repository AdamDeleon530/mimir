# ============================================================
# Mimir — environment variables
# Copy this to `.env` and fill in. Never commit `.env`.
# In Vercel: add these in Project Settings → Environment Variables.
# ============================================================

# Required ----------------------------------------------------

# Your Anthropic API key (https://console.anthropic.com)
NUXT_ANTHROPIC_API_KEY=sk-ant-...

# Password gate (any string — only you should know it)
NUXT_APP_PASSWORD=change-me-to-something-real

# Optional (recommended) --------------------------------------

# ElevenLabs API key (https://elevenlabs.io)
# Free tier: 10k chars/month. Mimir falls back to browser TTS if missing.
NUXT_ELEVENLABS_API_KEY=

# ElevenLabs voice ID. Default is "Brian" (calm, considered).
# Browse voices at https://elevenlabs.io/app/voice-library
# Defaults to nPczCjzI2devNBz1zQrb if unset.
NUXT_ELEVENLABS_VOICE_ID=nPczCjzI2devNBz1zQrb

# Live agency data integrations (stubbed in v1, wire when ready)
# -------------------------------------------------------------

# HubSpot Private App access token
NUXT_HUBSPOT_API_KEY=

# Stripe secret key
NUXT_STRIPE_SECRET_KEY=

# Smartlead / Instantly API key
NUXT_SMARTLEAD_API_KEY=
NUXT_INSTANTLY_API_KEY=
