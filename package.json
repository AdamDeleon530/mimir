    "typecheck": "nuxt typecheck",
    "sync-ops": "tsx scripts/sync-ops-context.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@nuxtjs/tailwindcss": "^6.12.2",
    "nuxt": "^3.14.0",
    "vue": "latest",
    "vue-router": "latest"
  },
  "devDependencies": {
    "@types/dom-speech-recognition": "^0.0.4",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
