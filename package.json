{
  "name": "mimir",
  "private": true,
  "type": "module",
  "description": "The Nordic Nerd's operational lens — voice + text interface to the agency.",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
